@page "/promotions/{Id:guid}"
@attribute [Authorize]
@using M2Portal.Services

<PageTitle>Promotion Detail — M2 Portal</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_detail is not null)
{
    @* Full-width action banner when pending approval *@
    @if (_detail.Status == PromotionStatus.PendingApproval)
    {
        <MudAlert Severity="Severity.Warning"
                  Class="mb-4"
                  Variant="Variant.Filled"
                  Icon="@Icons.Material.Filled.HowToVote">
            This promotion is awaiting approval.
            @if (_detail.ApprovalRequestId.HasValue)
            {
                <MudLink Href="@($"approvals/{_detail.ApprovalRequestId}")"
                         Color="Color.Inherit"
                         Class="ml-2">
                    View Approval →
                </MudLink>
            }
        </MudAlert>
    }

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@_detail.NameZht</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@_detail.NameEn</MudText>
        </MudStack>
        <MudSpacer />
        <MudChip T="string"
                 Color="@StatusColor(_detail.Status)"
                 Variant="Variant.Filled">
            @_detail.Status
        </MudChip>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Details</MudText>

                <MudSimpleTable Dense="true" Bordered="false">
                    <tbody>
                        <tr><td><strong>Type</strong></td><td>@_detail.Type</td></tr>
                        <tr><td><strong>Start Date</strong></td><td>@_detail.StartDate.ToString("yyyy-MM-dd")</td></tr>
                        <tr><td><strong>End Date</strong></td><td>@_detail.EndDate.ToString("yyyy-MM-dd")</td></tr>
                        <tr>
                            <td><strong>Stackable</strong></td>
                            <td>
                                @if (_detail.IsStackable)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Default" Size="Size.Small" />
                                }
                            </td>
                        </tr>
                        <tr><td><strong>Created</strong></td><td>@_detail.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
                        <tr><td><strong>Updated</strong></td><td>@_detail.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
                    </tbody>
                </MudSimpleTable>

                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Formula JSON</MudText>
                <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-grey);font-family:monospace;white-space:pre-wrap;overflow-x:auto;">@_detail.FormulaJson</MudPaper>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Actions</MudText>
                <MudStack Spacing="2">

                    @if (_detail.Status == PromotionStatus.Draft)
                    {
                        <MudButton Href="@($"promotions/{Id}/edit")"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   FullWidth="true">
                            Edit Draft
                        </MudButton>
                    }

                    @if (_detail.Status == PromotionStatus.Draft || _detail.Status == PromotionStatus.Paused)
                    {
                        <MudButton OnClick="ActivateAsync"
                                   Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   FullWidth="true"
                                   Disabled="_acting">
                            Activate
                        </MudButton>
                    }

                    @if (_detail.Status == PromotionStatus.Active)
                    {
                        <MudButton OnClick="PauseAsync"
                                   Variant="Variant.Filled"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Pause"
                                   FullWidth="true"
                                   Disabled="_acting">
                            Pause
                        </MudButton>
                    }

                    @if (_detail.ApprovalRequestId.HasValue)
                    {
                        <MudButton Href="@($"approvals/{_detail.ApprovalRequestId}")"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.HowToVote"
                                   FullWidth="true">
                            View Approval
                        </MudButton>
                    }

                    <MudButton Href="promotions"
                               Variant="Variant.Text"
                               FullWidth="true">
                        Back to List
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
