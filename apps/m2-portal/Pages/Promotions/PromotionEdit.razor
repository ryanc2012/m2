@page "/promotions/{Id:guid}/edit"
@attribute [Authorize]
@using M2Portal.Services

<PageTitle>Edit Promotion — M2 Portal</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<MudText Typo="Typo.h4" Class="mb-6">Edit Promotion</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_detail is not null)
{
    @if (_detail.Status != PromotionStatus.Draft)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Only Draft promotions can be edited. This promotion is <strong>@_detail.Status</strong>.
        </MudAlert>
        <MudButton Href="@($"promotions/{Id}")" Variant="Variant.Outlined">
            Back to Detail
        </MudButton>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="2" Style="max-width:720px">
            <MudForm @ref="_form">
                <MudGrid Spacing="3">

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_nameZht"
                                      Label="Name (Traditional Chinese / ZHT)"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="ZHT name is required." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_nameEn"
                                      Label="Name (English / EN)"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="English name is required." />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="_startDate"
                                       Label="Start Date"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="_endDate"
                                       Label="End Date"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       DateFormat="yyyy-MM-dd" />
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex align-center">
                        <MudSwitch @bind-Value="_isStackable"
                                   Label="Allow Stacking with Other Promotions"
                                   Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="_formulaJson"
                                      Label="Formula JSON"
                                      Variant="Variant.Outlined"
                                      Lines="6"
                                      Required="true"
                                      RequiredError="Formula JSON is required." />
                    </MudItem>

                    <MudItem xs="12">
                        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                            <MudButton Href="@($"promotions/{Id}")"
                                       Variant="Variant.Text"
                                       Disabled="_submitting">
                                Cancel
                            </MudButton>
                            <MudButton OnClick="SaveAsync"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="_submitting"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_submitting ? "Saving..." : "Save Changes")
                            </MudButton>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudPaper>
    }
}
