@using MudBlazor

<MudNavMenu>
    <MudNavLink Href="dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>
    <MudNavLink Href="promotions" Icon="@Icons.Material.Filled.LocalOffer">
        Promotions
    </MudNavLink>
    <MudNavLink Href="sales" Icon="@Icons.Material.Filled.PointOfSale">
        Sales
    </MudNavLink>
    <MudNavLink Href="attendance" Icon="@Icons.Material.Filled.AccessTime">
        Attendance
    </MudNavLink>
    <MudNavLink Href="approvals" Icon="@Icons.Material.Filled.HowToVote">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudText>Approvals</MudText>
            <MudBadge Content="@_pendingCount"
                      Visible="@(_pendingCount > 0)"
                      Color="Color.Warning"
                      Overlap="true"
                      Class="ml-1">
            </MudBadge>
        </MudStack>
    </MudNavLink>
    <MudDivider Class="my-2" />
    <MudText Typo="Typo.overline" Class="px-4 py-1" Color="Color.Secondary">Warehouse</MudText>
    <MudNavLink Href="goods-receipt" Icon="@Icons.Material.Filled.Inventory2">
        Goods Receipt
    </MudNavLink>
    <MudDivider Class="my-2" />
    <MudText Typo="Typo.overline" Class="px-4 py-1" Color="Color.Secondary">Reports</MudText>
    <MudNavLink Href="reporting/sales" Icon="@Icons.Material.Filled.BarChart">
        Sales Summary
    </MudNavLink>
    <MudNavLink Href="reporting/attendance" Icon="@Icons.Material.Filled.PeopleAlt">
        Attendance Summary
    </MudNavLink>
    <MudNavLink Href="notifications" Icon="@Icons.Material.Filled.Notifications">
        Notification Log
    </MudNavLink>
    <MudDivider Class="my-2" />
    <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">
        Settings
    </MudNavLink>
    <MudDivider Class="my-2" />
    <AuthorizeView>
        <Authorized>
            <MudText Typo="Typo.body2" Class="px-4 py-1">@context.User.Identity?.Name</MudText>
            <MudNavLink Href="MicrosoftIdentity/Account/SignOut" Icon="@Icons.Material.Filled.Logout">Sign out</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private int _pendingCount = 0;
}
